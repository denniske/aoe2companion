    "publish:ios": "PLATFORM=ios bash publish-no-sentry.sh",
    "publish:android": "PLATFORM=android bash publish-no-sentry.sh",
    "publish:all": "yarn publish:ios && yarn publish:android",
    "android": "expo run:android",
    "ios": "expo run:ios",
